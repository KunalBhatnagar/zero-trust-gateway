# ── Gateway ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_minimum_32_chars
ADMIN_KEY=your_admin_key_here

# ── Database ──────────────────────────────────────────────────
# These match the docker-compose.yml defaults — change in production
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://admin:password@localhost:5432/gateway_db

# ── External APIs ─────────────────────────────────────────────
# AbuseIPDB: free account at abuseipdb.com/register
# Leave as 'demo_mode' to skip IP reputation checks locally
ABUSEIPDB_KEY=demo_mode

# Slack: create incoming webhook at api.slack.com/apps
# Leave empty to skip Slack alerts
SLACK_WEBHOOK_URL=

# ── Upstream (the API this gateway protects) ──────────────────
UPSTREAM_URL=http://localhost:8080

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_KEY=your_admin_key_here

# ── Geo Blocking ──────────────────────────────────────────────
# Comma-separated ISO country codes to block (empty = allow all)
# Example: BLOCKED_COUNTRIES=CN,RU,KP
BLOCKED_COUNTRIES=